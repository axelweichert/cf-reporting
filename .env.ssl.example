# cf-reporting – SSL Configuration
# Copy this file to .env and fill in your values:
#   cp .env.ssl.example .env

# Required: Your domain name pointing to this server
# Multiple domains are supported (comma-separated):
#   SSL_DOMAIN=reports.example.com, dashboard.example.com
# Wildcard certificates are supported with ACME_CHALLENGE=dns:
#   SSL_DOMAIN=*.example.com
# Wildcards don't cover the bare domain – use both if needed:
#   SSL_DOMAIN=example.com, *.example.com
SSL_DOMAIN=reports.example.com

# Required: Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# ACME challenge type: "http" (default) or "dns"
# - http: Standard HTTP-01 challenge – port 80 must be accessible from the internet
# - dns:  DNS-01 challenge via Cloudflare API – works when port 80 is blocked
#         Requires CF_API_TOKEN or CF_DNS_TOKEN with Zone > DNS > Edit permission
ACME_CHALLENGE=http

# Required: Session encryption key (use a random string, 32+ characters)
SESSION_SECRET=

# Optional: Pre-configured Cloudflare User API token (skips browser setup)
# Required if ACME_CHALLENGE=dns (needs Zone > DNS > Edit permission)
CF_API_TOKEN=

# Optional: Pre-configured Cloudflare Account API token (alternative to CF_API_TOKEN)
# Use for account-owned tokens created under Manage Account > Account API Tokens
# If both CF_API_TOKEN and CF_ACCOUNT_TOKEN are set, CF_API_TOKEN takes priority
CF_ACCOUNT_TOKEN=

# Optional: Separate token for DNS-01 challenge only
# If not set, falls back to CF_API_TOKEN
# Use this to keep CF_API_TOKEN read-only while granting DNS write access separately
CF_DNS_TOKEN=

# Optional: Protect the site with a password (required when env tokens are set)
APP_PASSWORD=

# Optional: Enable a read-only "Viewer" role with a separate password.
# Viewers can browse dashboards and export reports but cannot manage schedules,
# trigger data collection, or access backup/restore.
# When set, the login page shows a role selector (Operator / Viewer).
VIEWER_PASSWORD=

# Optional: SMTP settings for email report delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# starttls (port 587), tls (port 465), or none (unencrypted)
SMTP_SECURITY=starttls

# Optional: Data collection schedule (cron expression, default: every 6 hours)
COLLECTION_SCHEDULE=0 */6 * * *

# Optional: How many days to keep collected snapshots (default: 365)
DATA_RETENTION_DAYS=365
