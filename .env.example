# cf-reporting – Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Session encryption key (use a random string, 32+ characters)
SESSION_SECRET=

# Optional: Pre-configured Cloudflare User API token (skips browser setup)
CF_API_TOKEN=

# Optional: Pre-configured Cloudflare Account API token (alternative to CF_API_TOKEN)
# Use for account-owned tokens created under Manage Account > Account API Tokens
# If both CF_API_TOKEN and CF_ACCOUNT_TOKEN are set, CF_API_TOKEN takes priority
CF_ACCOUNT_TOKEN=

# Protect the site with a password.
# REQUIRED when CF_API_TOKEN or CF_ACCOUNT_TOKEN is set – the app will refuse
# to serve data without it. Without APP_PASSWORD, env tokens would be accessible
# to any visitor who can reach the app.
APP_PASSWORD=

# Optional: SMTP settings for email report delivery (can also configure via Settings UI)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=true

# Optional: Set to "true" when behind a trusted reverse proxy (Caddy, nginx, etc.)
# Enables trusting X-Forwarded-For headers for rate limiting.
TRUSTED_PROXY=

# Optional: Set to "true" to mark session cookies as Secure (HTTPS only).
# Automatically set in docker-compose.ssl.yml.
SECURE_COOKIES=

# Optional: Data collection schedule (cron expression, default: every 6 hours)
COLLECTION_SCHEDULE=0 */6 * * *

# Optional: How many days to keep collected snapshots (default: 90)
DATA_RETENTION_DAYS=90

# Optional: Cloudflare R2 backup (S3-compatible)
# Enables "Backup to R2" buttons in Settings > Backup & Restore
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
